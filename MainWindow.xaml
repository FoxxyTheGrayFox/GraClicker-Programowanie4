<Window x:Class="ProjektClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ProjektClicker"
        Title="Poorly Designed Clicker Game"
        Width="1000"
        Height="640"
        Background="{DynamicResource ThemeBackground}">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource ThemePanelPrimary}"
                BorderBrush="{DynamicResource ThemeSurface}"
                BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="💾 Zapisz"
                            Command="{Binding SaveCommand}"
                            Margin="0,0,8,0"
                            Padding="12,4"
                            Background="{DynamicResource ThemeAccent}"
                            Foreground="{DynamicResource ThemeText}"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📂 Wczytaj"
                            Command="{Binding LoadCommand}"
                            Padding="12,4"
                            Background="{DynamicResource ThemeSurface}"
                            Foreground="{DynamicResource ThemeText}"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource ThemeText}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           Opacity="0.7"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Motyw:"
                               Foreground="{DynamicResource ThemeText}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Opacity="0.7"/>
                    <ComboBox ItemsSource="{Binding AvailableThemes}"
                              SelectedItem="{Binding SelectedTheme}"
                              Width="140"
                              Margin="0,0,8,0"
                              Background="{DynamicResource ThemeSurface}"
                              Foreground="{DynamicResource ThemeText}"
                              BorderThickness="0"/>
                    <Button Content="Zastosuj"
                            Command="{Binding ApplyThemeCommand}"
                            Padding="10,4"
                            Background="{DynamicResource ThemeAccent}"
                            Foreground="{DynamicResource ThemeText}"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Background="{DynamicResource ThemePanelPrimary}">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Border Background="{DynamicResource ThemeSurface}"
                            CornerRadius="12"
                            Padding="15"
                            Margin="10">
                        <TextBlock Text="{Binding PointsText}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeText}"
                                   TextAlignment="Center"/>
                    </Border>

                    <Button Content="Kliknij!"
                            Command="{Binding ClickCommand}"
                            Width="160"
                            Height="160"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="{DynamicResource ThemeAccent}"
                            Foreground="{DynamicResource ThemeText}"
                            BorderThickness="0"
                            Margin="10"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Cursor"
                                        Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="80">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1"
                  Background="{DynamicResource ThemePanelSecondary}">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Border Background="{DynamicResource ThemeSurface}"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,0,0,15">
                        <TextBlock Text="{Binding ClickyFact}"
                                   Width="320"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemeText}"
                                   TextAlignment="Center"/>
                    </Border>

                    <Border Background="{DynamicResource ThemeSurface}"
                            CornerRadius="20"
                            Padding="20"
                            Margin="0,0,0,15">
                        <Image Source="{Binding ClickyImage}"
                               Width="220"
                               Height="220"/>
                    </Border>

                    <Border Background="Gold"
                            CornerRadius="10"
                            Padding="8"
                            Visibility="{Binding BoostVisible,
                                         Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding BoostText}"
                                   FontWeight="Bold"
                                   Foreground="Black"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="2"
                  Background="{DynamicResource ThemePanelPrimary}">
                <StackPanel Margin="10">
                    <TextBlock Text="Sklep"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource ThemeText}"
                               Margin="5"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Upgrades}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="5"
                                            Height="70"
                                            Command="{Binding DataContext.BuyUpgradeCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource ThemeSurface}"
                                            Foreground="{DynamicResource ThemeText}"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <Button.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Description}"
                                                           Width="200"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Button.ToolTip>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="8"
                                                                    Padding="10">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"/>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Koszt: {0} | Ilość: {1}">
                                                        <Binding Path="Cost"/>
                                                        <Binding Path="Count"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Grid>
        </Grid>

        <Canvas Grid.Row="1"
                Background="{x:Null}">
            <Button Canvas.Left="{Binding BoostStarX}"
                    Canvas.Top="{Binding BoostStarY}"
                    Command="{Binding ClaimBoostCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Panel.ZIndex="99"
                    Visibility="{Binding BoostStarVisible,
                         Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <TextBlock Text="⭐"
                           FontSize="52"
                           ToolTip="Kliknij po boost x2!">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever"
                                                    AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1"
                                                             To="0.4"
                                                             Duration="0:0:0.6"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>
        </Canvas>
    </Grid>
</Window>