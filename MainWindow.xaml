<Window x:Class="ProjektClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ProjektClicker"
        Title="Poorly Clicker Game"
        Width="1000"
        Height="600"
        Background="#1E1E2E">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <!-- LEWY PANEL -->
        <Grid Grid.Column="0" Background="#2A2A40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Wyświetlanie punktów -->
                <Border Background="#3A3A5A"
                        CornerRadius="12"
                        Padding="15"
                        Margin="10">
                    <TextBlock Text="{Binding PointsText}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               TextAlignment="Center"/>
                </Border>

                <!-- Przycisk główny -->
                <Button Content="Kliknij!"
                        Command="{Binding ClickCommand}"
                        Width="160"
                        Height="160"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#6C63FF"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="10">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="80">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
        <!-- CENTRALNY PANEL -->
        <Grid Grid.Column="1" Background="#25253A">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Clicky Useless Facts -->
                <Border Background="#3A3A5A"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,0,0,15">
                    <TextBlock Text="{Binding ClickyFact}"
                               Width="320"
                               TextWrapping="Wrap"
                               Foreground="White"
                               TextAlignment="Center"/>
                </Border>
                <!-- Clicky -->
                <Border Background="#3A3A5A"
                        CornerRadius="20"
                        Padding="20"
                        Margin="0,0,0,15">
                    <Image Source="{Binding ClickyImage}"
                           Width="220"
                           Height="220"/>
                </Border>
                <!-- Boost -->
                <Border Background="Gold"
                        CornerRadius="10"
                        Padding="8"
                        Visibility="{Binding BoostVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding BoostText}"
                               FontWeight="Bold"
                               Foreground="Black"
                               TextAlignment="Center"/>
                </Border>
            </StackPanel>
        </Grid>
        <!-- PRAWY PANEL -->
        <Grid Grid.Column="2" Background="#2A2A40">
            <StackPanel Margin="10">
                <TextBlock Text="Sklep"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="5"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Upgrades}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="5"
                                        Height="70"
                                        Command="{Binding DataContext.BuyUpgradeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="#3A3A5A"
                                        Foreground="White"
                                        BorderThickness="0">
                                    <Button.ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Description}" Width="200" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Button.ToolTip>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Bold"/>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="Koszt: {0} | Ilość: {1}">
                                                    <Binding Path="Cost"/>
                                                    <Binding Path="Count"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Grid>
    </Grid>
</Window>